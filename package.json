{
  "name": "@oh-my-pi/omp-usage-status",
  "version": "0.1.0",
  "type": "module",
  "description": "OMP extension that appends current-provider coding-plan usage to the Pi status bar",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./usage-status": "./src/usage-status.ts"
  },
  "files": [
    "src"
  ],
  "omp": {
    "name": "Usage Status",
    "version": "0.1.0",
    "description": "Append current-provider usage information to the Pi status bar",
    "extensions": [
      "./src/index.ts"
    ],
    "settings": {
      "enabled": {
        "type": "boolean",
        "description": "Enable the usage status bar segment",
        "default": true
      },
      "scope": {
        "type": "enum",
        "description": "Which usage reports to display",
        "values": ["current-provider"],
        "default": "current-provider"
      },
      "refreshIntervalMs": {
        "type": "number",
        "description": "Low-frequency refresh interval for usage and reset countdowns",
        "default": 60000,
        "min": 5000,
        "step": 1000
      },
      "showReset": {
        "type": "boolean",
        "description": "Show relative reset time when available",
        "default": true
      },
      "warningThreshold": {
        "type": "number",
        "description": "Used-fraction threshold for warning styling",
        "default": 0.8,
        "min": 0,
        "max": 1,
        "step": 0.01
      },
      "criticalThreshold": {
        "type": "number",
        "description": "Used-fraction threshold for critical styling",
        "default": 0.95,
        "min": 0,
        "max": 1,
        "step": 0.01
      }
    }
  },
  "scripts": {
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-ai": ">=13.18.0",
    "@oh-my-pi/pi-coding-agent": ">=13.18.0"
  },
  "peerDependenciesMeta": {
    "@oh-my-pi/pi-ai": {
      "optional": true
    },
    "@oh-my-pi/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
